{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)

    "spacing": 4, // Gaps between modules (4px)

    "modules-left": [ "niri/workspaces", "niri/window"],
    "modules-center": ["clock","custom/media"],
    "modules-right": ["group/group-power", "group/hardware","battery", "pulseaudio", "tray"],
	"group/group-power": {
	    "orientation": "horizontal",
	    "drawer": {
		"transition-duration": 500,
		"children-class": "not-power",
		"transition-left-to-right": false,
	    },
	    "modules": [
		"custom/power",
		"custom/quit",
		"custom/lock",
		"custom/reboot",
	    ]
	},
	"custom/quit": {
	    "format": " ˇ░Ś╝ ",
	    "tooltip": false,
	    "on-click": "hyprctl dispatch exit"
	},
	"custom/lock": {
	    "format": " ˇ░Źü ",
	    "tooltip": false,
	    "on-click": "hyprlock"
	},
	"custom/reboot": {
	    "format": " ˇ░ťë ",
	    "tooltip": false,
	    "on-click": "reboot"
	},
	"custom/power": {
	    "format": " ´ÇĹ ",
	    "tooltip": false,
	    "on-click": "shutdown now"
	},
	"group/hardware": {
		"orientation": "horizontal",
		"drawer": {
			"transition-duration": 500,
			"children-class": "not-memory",
			"transition-left-to-right": false,
		},
		"modules": [
			"memory",
			"cpu",
			"temperature",
		]
	},
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "´Çú",
            "unlocked": "´éť"
        }
    },

