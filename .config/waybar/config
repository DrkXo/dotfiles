{
    // "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    // "height": 30, // Waybar height (to be removed for auto height)
		"reload_style_on_change": true,
    // "width": 1280, // Waybar width
    //"spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": ["clock", "hyprland/workspaces", "hyprland/scratchpad"],
    "modules-center": ["custom/media"],
    "modules-right": ["group/group-power", "group/hardware","battery", "pulseaudio", "tray"],
	"group/group-power": {
	    "orientation": "horizontal",
	    "drawer": {
		"transition-duration": 500,
		"children-class": "not-power",
		"transition-left-to-right": false,
	    },
	    "modules": [
		"custom/power", 
		"custom/quit",
		"custom/lock",
		"custom/reboot",
	    ]
	},
	"custom/quit": {
	    "format": " ґ░Ч╝ ",
	    "tooltip": false,
	    "on-click": "hyprctl dispatch exit"
	},
	"custom/lock": {
	    "format": " ґ░НБ ",
	    "tooltip": false,
	    "on-click": "hyprlock"
	},
	"custom/reboot": {
	    "format": " ґ░ЬЙ ",
	    "tooltip": false,
	    "on-click": "reboot"
	},
	"custom/power": {
	    "format": " яАС ",
	    "tooltip": false,
	    "on-click": "shutdown now"
	},
	"group/hardware": {
		"orientation": "horizontal",
		"drawer": {
			"transition-duration": 500,
			"children-class": "not-memory",
			"transition-left-to-right": false,
		},
		"modules": [
			"memory",
			"cpu",
			"temperature",
		]
	},
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "яАг",
            "unlocked": "яВЬ"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "яЛТ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "mpd": {
//        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) т╕и{songPosition}|{queueLength}т╕й {volume}% яАБ",
        "format": "яАБ  {title} - {artist} {stateIcon} [{elapsedTime:%M:%S}/{totalTime:%M:%S}] {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}[{songPosition}/{queueLength}] [{volume}%]",
        "format-disconnected": "яАБ Disconnected",
        "format-stopped": "яАБ {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": "яГД "
        },
        "random-icons": {
//            "off": "<span color=\"#f53c3c\">яБ┤</span> ",
            "on": "яБ┤ "
        },
        "repeat-icons": {
            "on": "яАЮ "
        },
        "single-icons": {
            "on": "яАЮ1 "
        },
        "state-icons": {
            "paused": "яБМ",
            "playing": "яБЛ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)",
        "on-click": "mpc toggle",
        "on-click-right": "foot -a ncmpcpp ncmpcpp",
        "on-scroll-up": "mpc volume +2",
        "on-scroll-down": "mpc volume -2"

    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо ",
            "deactivated": "яБ░ "
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        //"format-alt": "{:%Y-%m-%d}"
        "format": "<big>{:%H:%M}</big> яАЧ "
        //"format": "{:%Y-%m-%d %H:%M}"
    },
    "cpu": {
        "format": "яЛЫ {usage}%",
//        "tooltip": false
    },
    "memory": {
        "format": "яГЙ {}%"
    },
    "temperature": {
        "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 80,
        "format-critical": "{icon} {temperatureC}┬░C",
        "format": "{icon} {temperatureC}┬░C",
        "format-icons": ["яЭл", "яЛЙ", "яЭй"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{icon} {percent}%",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": " ґ░ВЕ {capacity}%",
        "format-plugged": "яЗж {capacity}%",
        "format-alt": "{icon} {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) яЗл",
        "format-ethernet": "ю╣Ж {ifname}",
        "tooltip-format": "яЮЦ {ifname} via {gwaddr}",
        "format-linked": "яЮЦ {ifname} (No IP)",
        "format-disconnected": "Disconnected тЪа {ifname}",
        "format-alt": "яЮЦ {ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        "scroll-step": 5, // %, can be a float
        "format": "{icon} {format_source}",
        "format-bluetooth": "яКФ {icon} {volume}% {format_source}",
        "format-bluetooth-muted": "яЪй яКФ {icon} {format_source}",
        "format-muted": "ґ░ЭЯ {format_source}",
        "format-source": "яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
//            "headphone": "яАе ",
//            "hands-free": "яЦР ",
//            "headset": "яЦР",
//            "phone": "яВХ",
//            "portable": "яВХ",
//            "car": "яЖ╣",
            "default": ["яАж", "яАз ", "яАи "]
        },
        "on-click": "pavucontrol",
        "on-click-right": "foot -a pw-top pw-top"
    },
    "hyprland/window": {
	    "format": "ЁЯСЙ {}",
	    "rewrite": {
		"(.*) тАФ Mozilla Firefox": "ЁЯМО $1",
		"(.*) - fish": "> [$1]"
	    },
	    "separate-outputs": true
    },
    "hyprland/workspaces": {
	    "format": "{name}: {icon}",
	    "format-icons": {
		"1": "юоК",
		"2": "юоК",
		"3": "юоК",
		"4": "юоК",
		"5": "юоК",
		"urgent": "!",
		"default": "яТк ",
		"active": "яУ╡ ",
	    }
    },
    "custom/media": {
	    "format": "ґ░Д╛ {0} {1} ґ░Д╜",
	    "escape": true,
	    "return-type": "json",
	    "max-length": 40,
	    "on-click": "playerctl play-pause",
	    "on-click-right": "playerctl stop",
	    "smooth-scrolling-threshold": 10, 
	    "on-scroll-up": "playerctl next",
	    "on-scroll-down": "playerctl previous",
	    "exec": "python $HOME/.config/waybar/mediaplayer.py 2> /dev/null", 
	},
	"custom/left": {
		"format": "<span size='20pt'>юВ░</span>",
	},
	"custom/right": {
		"format": "<span size='20pt'>юВ▓</span>",
	},
	"custom/secondleft": {
		"format": "<span size='20pt'>юВ░</span>",
	},
	"custom/secondright": {
		"format": "<span size='20pt'>юВ▓</span>",
	},
	"custom/thirdleft": {
		"format": "<span size='20pt'>юВ░</span>",
	},
	"custom/thirdright": {
		"format": "<span size='20pt'>юВ▓</span>",
	},
},
